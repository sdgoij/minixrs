{
  "arch": "riscv64",
  "cpu": "generic-rv64",
  "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n64-S128",
  "disable-redzone": true,
  "features": "+m,+a,+f,+d,+c",
  "linker-flavor": "ld.lld",
  "llvm-target": "riscv64-unknown-none-elf",
  "max-atomic-width": 64,
  "os": "none",
  "panic-strategy": "abort",
  "relocation-model": "static",
  "target-pointer-width": 64,
  "vendor": "unknown"
}
